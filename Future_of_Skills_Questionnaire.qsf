ionDescription":"Thank you for completing the questionnaire. What are your thoughts on the questionnaire, now that...","Choices":{"1":{"Display":"How clear and understandable have the questions been?"},"2":{"Display":"How easy has the questionnaire been to navigate?"},"3":{"Display":"How relatable have the options been to your job ?"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"Labels":[],"QuestionID":"QID153","QuestionText_Unsafe":"End of questionnaire feedback<br>"}},{"SurveyID":"SV_6imZX3bWIpllbIq","Element":"SQ","PrimaryAttribute":"QID157","SecondaryAttribute":"Below there is a list of common job tasks. Select 5 tasks from the list below that best summarise...","TertiaryAttribute":null,"Payload":{"QuestionText":"Below there is a list of common job tasks. <br><br>Select 5 tasks from the list below that best summarise the day-to-day work you do as part of your job.<br><br>If there is a task that you believe is essential to your role, but there is no similar task included in the list below, select \"other\" to specify that task.<br><br><i>Tip: hover the cursor over a task for more information<\/i><br><br><br>","DataExportTag":"Q3.1","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Below there is a list of common job tasks. Select 5 tasks from the list below that best summarise...","Choices":{"1":{"Display":"<span title=\"e.g., learning about latest developments, researching a product or client\">Finding out information<\/span>"},"2":{"Display":"<span title=\"e.g., inspecting products or documents, interviewing staff or reviewing their performance, ensuring compliance with regulations or guidelines\">Checking quality<\/span>"},"3":{"Display":"<span title=\"e.g., deciding project goals, choosing between different plans or options\">Making decisions<\/span>"},"4":{"Display":"<span title=\"e.g., finding ways to overcome roadblocks, fix issues in software or machines, or resolve conflict\">Solving problems<\/span>"},"5":{"Display":"<span title=\"e.g., coming up with new ideas for products or marketing, innovating\">Thinking creatively<\/span>"},"6":{"Display":"<span title=\"e.g., considering the overall goals for a project, setting objectives, strategising\">Long-term planning<\/span>"},"7":{"Display":"<span title=\"e.g., scheduling your time, deciding which tasks are most important and the order they should be completed\">Short-term planning<\/span>"},"8":{"Display":"<span title=\"e.g., using physical tools or machines, using your hands to move, alter or affect physical objects\">Working with tools or materials<\/span>"},"9":{"Display":"<span title=\"e.g., interacting with computer software, email or apps to communicate or complete a task\">Using computer software<\/span>"},"10":{"Display":"<span title=\"e.g., creating programmes or interacting with a computer using a programming language, instead of a user interface\">Writing code<\/span>"},"11":{"Display":"<span title=\"e.g., structuring, processing or cleaning data for storage or later use\">Manipulating or organising data<\/span>"},"12":{"Display":"<span title=\"e.g., running statistical tests, consulting graphs, drawing insights\">Interpreting or analysing data<\/span>"},"13":{"Display":"<span title=\"e.g., speaking to colleagues, writing articles, delivering a sales pitch\">Communicating ideas or instructions to others<\/span>"},"47":{"Display":"<span title=\"e.g., taking instructions, reading documents, listening to feedback\">Interpreting ideas or instructions communicated by others<\/span>"},"48":{"Display":"<span title=\"e.g., developing rapport with clients or colleagues, nurturing existing relationships\">Developing relationships with others<\/span>"},"52":{"Display":"<span